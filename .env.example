# Environment Variables Template
# Copy this file to .env and fill in the values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# MERCADOPAGO CONFIGURATION
# ===========================================
# Get these from: https://www.mercadopago.com.ar/developers/panel/app
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx

# ===========================================
# CALENDLY CONFIGURATION  
# ===========================================
# Create events in Calendly and paste the URLs here
VITE_CALENDLY_URL_INDIVIDUAL=https://calendly.com/your-username/individual
VITE_CALENDLY_URL_TALLER=https://calendly.com/your-username/taller
VITE_CALENDLY_URL_PRESENCIAL=https://calendly.com/your-username/presencial

# ===========================================
# SITE CONFIGURATION
# ===========================================
VITE_SITE_URL=http://localhost:8081
